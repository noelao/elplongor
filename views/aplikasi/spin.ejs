<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pasukan Roll — Spin</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d0e14;
      --surface: #181922;
      --border: rgba(255,255,255,0.08);
      --muted: #8b8d9e;
      --accent: #f0c040;
      --win: #22c55e;
      --locked-glow: rgba(34,197,94,0.25);
    }

    body {
      background: var(--bg);
      color: #f0f0f5;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 1rem 2rem;
    }

    /* ── header ── */
    .header { text-align: center; margin-bottom: 1.5rem; }
    .header h1 {
      font-family: 'Syne', sans-serif;
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--accent);
      letter-spacing: -0.5px;
    }
    .header p { font-size: 12px; color: var(--muted); margin-top: 3px; }

    /* ── preset selector ── */
    .preset-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 1.5rem;
    }
    .preset-label {
      font-size: 12px;
      color: var(--muted);
      white-space: nowrap;
    }
    .preset-btns {
      display: flex;
      gap: 6px;
    }
    .preset-btn {
      width: 40px; height: 36px;
      border-radius: 8px;
      border: 1.5px solid var(--border);
      background: #181922;
      color: #f0f0f5;
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s, color 0.15s;
    }
    .preset-btn.active {
      border-color: var(--accent);
      background: var(--accent);
      color: #0d0e14;
    }
    .preset-btn:disabled {
      opacity: 0.35;
      cursor: default;
    }

    /* ── loading ── */
    #loading-wrap { display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .loading-bar {
      width: 200px; height: 3px;
      background: #21222e;
      border-radius: 4px;
      overflow: hidden;
    }
    .loading-bar-inner {
      height: 100%;
      background: var(--accent);
      border-radius: 4px;
      animation: loadBar 1.2s ease-in-out infinite;
    }
    @keyframes loadBar {
      0%   { width: 0%;  margin-left: 0; }
      50%  { width: 60%; margin-left: 20%; }
      100% { width: 0%;  margin-left: 100%; }
    }
    .loading-text { font-size: 13px; color: var(--muted); }

    /* ── error ── */
    #error-wrap { display: none; }
    .error-box {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.3);
      border-radius: 10px;
      padding: 1rem 1.5rem;
      font-size: 13px;
      color: #f87171;
      text-align: center;
    }

    /* ── main ── */
    #main-wrap { display: none; flex-direction: column; align-items: center; width: 100%; }

    /* ── reels grid ── */
    .reels {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      margin-bottom: 1.75rem;
      width: 100%;
      max-width: 360px;
    }

    .reel-frame {
      border-radius: 14px;
      border: 1.5px solid var(--border);
      background: var(--surface);
      overflow: hidden;
      position: relative;
      display: flex; align-items: center; justify-content: center;
      transition: border-color 0.3s, box-shadow 0.3s, width 0.25s, height 0.25s;
      flex-shrink: 0;
    }
    .reel-frame.locked {
      border-color: #22c55e;
      box-shadow: 0 0 0 3px var(--locked-glow);
    }
    .reel-frame img {
      width: 100%; height: 100%;
      object-fit: cover;
      border-radius: 12px;
    }
    .reel-frame.spinning img {
      filter: blur(1.5px) brightness(0.8);
    }
    .lock-badge {
      position: absolute;
      top: 6px; right: 6px;
      width: 20px; height: 20px;
      background: #22c55e;
      border-radius: 50%;
      font-size: 10px;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      opacity: 0; transform: scale(0.7);
      transition: opacity 0.25s, transform 0.25s;
      z-index: 2;
    }
    .reel-frame.locked .lock-badge { opacity: 1; transform: scale(1); }
    .reel-name {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      background: linear-gradient(transparent, rgba(0,0,0,0.75));
      padding: 14px 4px 5px;
      text-align: center;
      font-size: 10px; font-weight: 500; color: #fff;
      border-radius: 0 0 12px 12px;
      text-transform: capitalize;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .reel-frame.win-pulse { animation: winPulse 0.45s ease 4; }
    @keyframes winPulse {
      0%   { transform: scale(1);    box-shadow: 0 0 0 3px var(--locked-glow); }
      50%  { transform: scale(1.07); box-shadow: 0 0 20px 6px var(--locked-glow); }
      100% { transform: scale(1);    box-shadow: 0 0 0 3px var(--locked-glow); }
    }

    /* ── tombol spin ── */
    .btn-spin {
      background: var(--accent);
      color: #0d0e14;
      border: none;
      border-radius: 12px;
      padding: 0.8rem 0;
      width: 100%;
      max-width: 280px;
      font-family: 'Syne', sans-serif;
      font-size: 17px; font-weight: 800;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: transform 0.12s, opacity 0.12s;
      margin-bottom: 1.25rem;
    }
    .btn-spin:hover  { opacity: 0.88; transform: scale(1.02); }
    .btn-spin:active { transform: scale(0.96); }
    .btn-spin:disabled { opacity: 0.3; cursor: default; transform: none; }

    /* ── hasil ── */
    .result {
      font-family: 'Syne', sans-serif;
      font-size: 18px; font-weight: 700;
      min-height: 28px; text-align: center;
      letter-spacing: -0.2px;
      padding: 0 1rem;
    }
    .result.win  { color: var(--win); }
    .result.lose { color: var(--muted); }

    .counter { font-size: 12px; color: var(--muted); margin-top: 6px; }
  </style>
</head>
<body>

  <div class="header">
    <h1>🎰 Pasukan Roll</h1>
    <p>Cocokkan 3 pasukan yang sama untuk menang!</p>
  </div>

  <!-- preset selector -->
  <div class="preset-wrap" id="preset-wrap" style="display:none">
    <span class="preset-label">Slot:</span>
    <div class="preset-btns">
      <button class="preset-btn active" data-val="3" onclick="setPreset(3)">3</button>
      <button class="preset-btn"        data-val="4" onclick="setPreset(4)">4</button>
      <button class="preset-btn"        data-val="5" onclick="setPreset(5)">5</button>
      <button class="preset-btn"        data-val="6" onclick="setPreset(6)">6</button>
    </div>
  </div>

  <!-- loading -->
  <div id="loading-wrap">
    <div class="loading-bar"><div class="loading-bar-inner"></div></div>
    <p class="loading-text">Memuat data pasukan...</p>
  </div>

  <!-- error -->
  <div id="error-wrap">
    <div class="error-box" id="error-msg"></div>
  </div>

  <!-- main -->
  <div id="main-wrap">
    <div class="reels" id="reels"></div>
    <button class="btn-spin" id="spin-btn" onclick="startSpin()">▶ SPIN</button>
    <div class="result" id="result"></div>
    <div class="counter" id="counter"></div>
  </div>

  <script>
    let allPasukan  = [];
    let locked      = [];
    let intervals   = [];
    let isSpinning  = false;
    let spinCount   = 0;
    let slotCount   = 3;

    // SFX
    const sfxClick = new Audio('/sound/sfx/click.mp3');
    function playClick() { sfxClick.currentTime = 0; sfxClick.play().catch(() => {}); }

    const sfxSpin = new Audio('/sound/sfx/typing2.mp3');
    sfxSpin.loop   = true;
    sfxSpin.volume = 0.3;
    function spinStart() { sfxSpin.currentTime = 0; sfxSpin.play().catch(() => {}); }
    function spinStop()  { sfxSpin.pause(); sfxSpin.currentTime = 0; }

    // ── fetch ──────────────────────────────────────────────────────
    fetch('/api/pasukanRoll')
      .then(res => {
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      })
      .then(data => {
        console.log(data);
        if (!data || data.length < 3)
          throw new Error('Data pasukan kurang dari 3');
        allPasukan = data;
        init();
      })
      .catch(err => {
        document.getElementById('loading-wrap').style.display = 'none';
        document.getElementById('error-wrap').style.display  = 'block';
        document.getElementById('error-msg').textContent     = '⚠️ Gagal memuat pasukan: ' + err.message;
      });

    // ── init ───────────────────────────────────────────────────────
    function init() {
      document.getElementById('loading-wrap').style.display = 'none';
      document.getElementById('main-wrap').style.display    = 'flex';
      document.getElementById('preset-wrap').style.display  = 'flex';
      buildReels(slotCount);
    }

    // ── ukuran reel berdasarkan jumlah slot ────────────────────────
    function reelSize(count) {
      if (count <= 3) return 80;
      if (count === 4) return 110;
      if (count === 5) return 80;
      return 80; // 6
    }

    // ── bangun reel DOM ────────────────────────────────────────────
    function buildReels(count) {
      const container = document.getElementById('reels');
      container.innerHTML = '';
      locked    = Array(count).fill(false);
      intervals = Array(count).fill(null);

      const size = reelSize(count) + 'px';

      for (let i = 0; i < count; i++) {
        const frame = document.createElement('div');
        frame.className = 'reel-frame';
        frame.id = 'reel-' + i;
        frame.style.width  = size;
        frame.style.height = size;

        frame.innerHTML = `
          <img id="img-${i}" src="" alt="" />
          <div class="reel-name" id="name-${i}"></div>
          <div class="lock-badge">✓</div>
        `;
        container.appendChild(frame);
        setReel(i, rand());
      }
    }

    // ── ganti preset ───────────────────────────────────────────────
    function setPreset(val) {
      if (isSpinning) return;
      slotCount = val;

      document.querySelectorAll('.preset-btn').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.val) === val);
      });

      buildReels(val);
      document.getElementById('result').textContent  = '';
      document.getElementById('result').className    = 'result';
      document.getElementById('counter').textContent = '';
    }

    // ── helpers ────────────────────────────────────────────────────
    function rand() {
      return allPasukan[Math.floor(Math.random() * allPasukan.length)];
    }

    function setReel(idx, p) {
      document.getElementById('img-'  + idx).src         = p.path;
      document.getElementById('img-'  + idx).alt         = p.name;
      document.getElementById('name-' + idx).textContent = p.name;
    }

    // ── spin ───────────────────────────────────────────────────────
    function startSpin() {
      if (isSpinning) return;
      isSpinning = true;
      spinCount++;
      playClick();
      spinStart();

      // nonaktifkan preset saat spinning
      document.querySelectorAll('.preset-btn').forEach(b => b.disabled = true);

      for (let i = 0; i < slotCount; i++) {
        locked[i] = false;
        const f = document.getElementById('reel-' + i);
        f.classList.remove('locked', 'win-pulse');
        f.classList.add('spinning');
      }

      document.getElementById('result').textContent   = '';
      document.getElementById('result').className     = 'result';
      document.getElementById('counter').textContent  = '';
      document.getElementById('spin-btn').disabled    = true;
      document.getElementById('spin-btn').textContent = '⏳ Spinning...';

      // target akhir tiap reel
      const targets = Array.from({ length: slotCount }, rand);

      // flash cepat
      for (let i = 0; i < slotCount; i++) {
        intervals[i] = setInterval(() => {
          if (!locked[i]) setReel(i, rand());
        }, 75);
      }

      // hentikan berurutan — jeda 550ms antar reel
      for (let i = 0; i < slotCount; i++) {
        setTimeout((idx => () => {
          clearInterval(intervals[idx]);
          locked[idx] = true;
          setReel(idx, targets[idx]);
          const f = document.getElementById('reel-' + idx);
          f.classList.remove('spinning');
          f.classList.add('locked');
          playClick();
          if (idx === slotCount - 1) {
            spinStop();
            setTimeout(() => evalResult(targets), 200);
          }
        })(i), 600 + i * 550);
      }
    }

    // ── evaluasi — menang bila ada 3 nama yang sama ────────────────
    function evalResult(targets) {
      isSpinning = false;
      document.getElementById('spin-btn').disabled    = false;
      document.getElementById('spin-btn').textContent = '▶ SPIN';
      document.getElementById('counter').textContent  = `Putaran ke-${spinCount}`;
      document.querySelectorAll('.preset-btn').forEach(b => b.disabled = false);

      const el     = document.getElementById('result');
      const counts = {};
      targets.forEach(t => counts[t.name] = (counts[t.name] || 0) + 1);
      const maxCount  = Math.max(...Object.values(counts));
      const maxName   = Object.keys(counts).find(k => counts[k] === maxCount);
      const winFrames = targets
        .map((t, i) => ({ t, i }))
        .filter(o => o.t.name === maxName)
        .map(o => o.i);

      if (maxCount >= 3) {
        el.textContent = `🎉 JACKPOT! ${maxCount}x ${maxName.toUpperCase()} MENANG!`;
        el.className   = 'result win';
        winFrames.forEach(i =>
          document.getElementById('reel-' + i).classList.add('win-pulse')
        );
      } else if (maxCount === 2) {
        el.textContent = '😅 Hampir! 2 cocok — spin lagi!';
        el.className   = 'result lose';
      } else {
        el.textContent = '❌ Tidak ada yang cocok.';
        el.className   = 'result lose';
      }
    }
  </script>

</body>
</html>
