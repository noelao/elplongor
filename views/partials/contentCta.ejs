<script>
    const pilihTh = document.querySelector('.memilihTH');
    const pilihanOpsi = document.querySelector('.pilihanOpsi');

    const memilihKategori = document.querySelector('.memilihKategori');
    const pilihanOpsiKategori = document.querySelector('.pilihanOpsiKategori');

    pilihTh.addEventListener("click", function(){
        console.log("pencet");
        pilihTh.classList.toggle('sedangMemilih');
        pilihanOpsi.classList.toggle('actived');
    });

    memilihKategori.addEventListener("click", function(){
        console.log("pencet");
        memilihKategori.classList.toggle('sedangMemilih');
        pilihanOpsiKategori.classList.toggle('pilihanOpsiKategoriMuncul');
    });
    pilihanOpsiKategori.querySelector(".background").addEventListener("click", function(){
        memilihKategori.classList.toggle('sedangMemilih');
        pilihanOpsiKategori.classList.toggle('pilihanOpsiKategoriMuncul');
    });
        


</script>

