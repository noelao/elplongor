        <div class="filter">
            <div class="tengah">
                <div class="terpilihBg"></div>
                <div class="pilihan tombol terbaik terpilih">
                    <h2>terbaik</h2>
                </div>
                <div class="pilihan tombol terbaru">
                    <h2>terbaru</h2>
                </div>
                <div class="pilihan tombol terlama">
                    <h2>terlama</h2>
                </div>
            </div>
        </div>

        <script>
            const pilihanFilter = document.querySelectorAll(".filter .tengah .pilihan");
            const terpilihBg= document.querySelector(".filter .tengah .terpilihBg");

            pilihanFilter.forEach((ini, i) => {
                ini.addEventListener("click", function(){
                    pilihanFilter.forEach((ini) => {
                        ini.classList.remove("terpilih");
                    });

                    ini.classList.add("terpilih");

                    const lebarParent = terpilihBg.parentElement.clientWidth;
                    const lebarClient = ini.clientWidth;
                    console.log(lebarClient);

                    const iInt = parseInt(i);
                    
                    terpilihBg.style.left = `calc(.2rem + (${lebarParent}px - .4rem) * ${i/3})`;
                    terpilihBg.style.width = `calc(${lebarClient}px + 1.4rem)`;

                });
            });
        </script>

